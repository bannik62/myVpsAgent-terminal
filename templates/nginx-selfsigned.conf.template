server {
    listen 443 ssl;
    server_name {{IP}};

    ssl_certificate /etc/ssl/mcp/cert.pem;
    ssl_certificate_key /etc/ssl/mcp/key.pem;

    # MCP Shell endpoint
    location /mcp/shell {
        # Auth par token
        if ($http_authorization != "Bearer {{MCP_TOKEN}}") {
            return 403;
        }

        proxy_pass http://127.0.0.1:{{MCP_PORT}}/;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection 'upgrade';
        proxy_set_header Host $host;
        proxy_set_header X-Forwarded-Proto https;
        proxy_cache_bypass $http_upgrade;

        # Nécessaire pour le streaming MCP
        proxy_buffering off;
        proxy_read_timeout 300s;
    }
}

# Redirection HTTP → HTTPS
server {
    listen 80;
    server_name {{IP}};
    return 301 https://{{IP}}$request_uri;
}
