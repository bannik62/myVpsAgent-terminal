<VirtualHost *:443>
    ServerName {{IP}}

    SSLEngine on
    SSLCertificateFile /etc/ssl/mcp/cert.pem
    SSLCertificateKeyFile /etc/ssl/mcp/key.pem

    # MCP Shell endpoint
    <Location /mcp/shell>
        ProxyPass http://127.0.0.1:{{MCP_PORT}}/
        ProxyPassReverse http://127.0.0.1:{{MCP_PORT}}/

        SetEnvIf Authorization "Bearer {{MCP_TOKEN}}" AUTHORIZED=1
        <RequireAll>
            Require env AUTHORIZED
        </RequireAll>

        RequestHeader set X-Forwarded-Proto "https"
        ProxyPreserveHost On
    </Location>

</VirtualHost>

<VirtualHost *:80>
    ServerName {{IP}}
    Redirect permanent / https://{{IP}}/
</VirtualHost>
