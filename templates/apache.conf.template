<VirtualHost *:443>
    ServerName {{DOMAIN}}

    SSLEngine on
    SSLCertificateFile {{SSL_CERT}}
    SSLCertificateKeyFile {{SSL_KEY}}

    # MCP Shell endpoint
    <Location /mcp/shell>
        ProxyPass http://127.0.0.1:{{MCP_PORT}}/
        ProxyPassReverse http://127.0.0.1:{{MCP_PORT}}/

        # Auth par token
        SetEnvIf Authorization "Bearer {{MCP_TOKEN}}" AUTHORIZED=1
        <RequireAll>
            Require env AUTHORIZED
        </RequireAll>

        # Headers
        RequestHeader set X-Forwarded-Proto "https"
        ProxyPreserveHost On
    </Location>

</VirtualHost>

# Redirection HTTP → HTTPS
<VirtualHost *:80>
    ServerName {{DOMAIN}}
    Redirect permanent / https://{{DOMAIN}}/
</VirtualHost>
